# Server
PORT=3001

# OAuth 2.0 Agent (Auth Code Flow)
WORKDAY_AUTH_URL=https://us.agent.workday.com/auth/authorize/deloitte_dpt12
WORKDAY_TOKEN_URL=https://us.agent.workday.com/auth/auth/deloitte_dpt12/token
WORKDAY_CLIENT_ID=your_oauth_client_id
WORKDAY_CLIENT_SECRET=your_oauth_client_secret
WORKDAY_REDIRECT_URI=http://localhost:3001/callback
WORKDAY_SCOPE=full

# ASOR API Client (for Workday REST API calls)
WORKDAY_ASOR_CLIENT_ID=your_asor_client_id
WORKDAY_ASOR_CLIENT_SECRET=your_asor_client_secret
WORKDAY_ASOR_TOKEN_URL=https://us.agent.workday.com/auth/auth/deloitte_dpt12/token

# Workday REST API Base
WORKDAY_API_BASE=https://us.agent.workday.com/api/v1/deloitte_dpt12
